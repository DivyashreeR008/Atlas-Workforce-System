# Auth Service
PORT=8010
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_DEFAULT_PASSWORD=ChangeMe123!
POSTGRES_URL=postgresql://atlas_user:atlas_password@postgres:5432/atlas_db
POSTGRES_SSL=false
ALLOWED_ORIGINS=http://localhost:3000

# Audit Service Integration
AUDIT_SERVICE_URL=http://audit-compliance-service:8011
AUDIT_INTERNAL_KEY=atlas-internal-key-change-in-prod

# SAML Configuration
SAML_IDP_SSO_URL=https://idp.example.com/sso
SAML_IDP_ENTITY_ID=https://idp.example.com/metadata

# SCIM Configuration
SCIM_API_KEY=change-scim-api-key-in-production
