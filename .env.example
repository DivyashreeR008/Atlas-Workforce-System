# Atlas Workforce System — environment template
NODE_ENV=development

# API Gateway
PORT=8080
JWT_SECRET=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000
AUTH_SERVICE_URL=http://localhost:8010
EMPLOYEE_SERVICE_URL=http://localhost:8001
PAYROLL_SERVICE_URL=http://localhost:8002
ANALYTICS_SERVICE_URL=http://localhost:8003
NOTIFICATION_SERVICE_URL=http://localhost:8004
ATTENDANCE_SERVICE_URL=http://localhost:8005
LEAVE_SERVICE_URL=http://localhost:8006
ATS_SERVICE_URL=http://localhost:8012
LMS_SERVICE_URL=http://localhost:8013
PERFORMANCE_SERVICE_URL=http://localhost:8014
AI_COPILOT_SERVICE_URL=http://localhost:8015
AUDIT_COMPLIANCE_SERVICE_URL=http://localhost:8011
AUDIT_INTERNAL_KEY=atlas-internal-key-change-me
REDIS_URL=redis://localhost:6379

# Auth Service
POSTGRES_URL=postgresql://atlas_user:REDACTED_DATABASE_PASSWORD@localhost:5432/atlas_db
POSTGRES_SSL=false
ADMIN_DEFAULT_PASSWORD=ChangeMe123!

# Employee Service
MONGO_URL=mongodb://admin:REDACTED_DATABASE_PASSWORD@localhost:27017/atlas_db?authSource=admin

# ATS Service
ATS_DATABASE_URL=postgresql://atlas_user:REDACTED_DATABASE_PASSWORD@localhost:5432/atlas_db

# LMS Service
LMS_DB_HOST=localhost
LMS_DB_USER=atlas_user
LMS_DB_PASSWORD=REDACTED_DATABASE_PASSWORD
LMS_DB_NAME=atlas_db
LMS_DB_PORT=5432

# Performance Service
PERFORMANCE_SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/atlas_db
PERFORMANCE_SPRING_DATASOURCE_USERNAME=atlas_user
PERFORMANCE_SPRING_DATASOURCE_PASSWORD=REDACTED_DATABASE_PASSWORD

# AI Copilot Service
OPENAI_API_KEY=

# Audit & Compliance Service
AUDIT_DATABASE_URL=postgresql://atlas_user:REDACTED_DATABASE_PASSWORD@localhost:5432/atlas_db
AUDIT_INTERNAL_KEY=atlas-internal-key-change-me

